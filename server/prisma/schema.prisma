generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// 공통 코드 (상태, 이력 유형, 위치 유형 등)
// groupCode 예: PLANT_STATUS, HISTORY_TYPE, LOCATION_TYPE
// ─────────────────────────────────────────────
model CommonCode {
  id          String   @id @default(cuid())
  groupCode   String
  code        String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plantsByStatus     Plant[]        @relation("PlantStatus")
  plantsByOriginType Plant[]        @relation("OriginType")
  historiesByType    PlantHistory[] @relation("HistoryType")
  locationsByType    PlantLocation[] @relation("LocationType")

  @@unique([groupCode, code])
  @@index([groupCode, isActive])
  @@map("common_codes")
}

// ─────────────────────────────────────────────
// 공통코드 그룹 표시명 (groupCode는 변경 불가, name만 관리)
// ─────────────────────────────────────────────
model CommonCodeGroup {
  groupCode String   @id
  name      String
  updatedAt DateTime @updatedAt

  @@map("common_code_groups")
}

// ─────────────────────────────────────────────
// QR 일련번호 — 접두사별 원자적 증가
//
// QR 번호 규칙: {PREFIX}-{SEQUENCE(6자리)}
//   예) CON-000001, LTH-000001, CAT-000001
//
// - PREFIX: Species.category.code (PlantCategory, 3자리 대문자)
// - SEQUENCE: 접두사별 독립 카운터 (QrSequence.lastNumber + 1)
// - 미분류 품종(categoryId null): OTH-000001
// - 생성 시 트랜잭션으로 QrSequence 업데이트 후 Plant.qrCode 저장
// ─────────────────────────────────────────────
model QrSequence {
  prefix     String   @id @db.VarChar(3)
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@map("qr_sequences")
}

// ─────────────────────────────────────────────
// 품종 대분류 — QR 접두사의 근거 (CON, LTH, CAT, AFR, OTH 등)
// Species.qrPrefix를 대체: 접두사를 Species마다 중복 저장하지 않고
// 카테고리 1곳에서 관리한다.
// ─────────────────────────────────────────────
model PlantCategory {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(3)
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  species Species[]

  @@map("plant_categories")
}

// ─────────────────────────────────────────────
// 사용자
// ─────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedPlants    Plant[]        @relation("PlantOwner")
  ownedImages    PlantImage[]   @relation("ImageOwner")
  ownedHistories PlantHistory[] @relation("HistoryOwner")
  ownedLocations PlantLocation[] @relation("LocationOwner")
  cartItems      Cart[]
  plantHistories PlantHistory[] @relation("HistoryPerformer")
  orderRequests  OrderRequest[]
  collectorProfile CollectorProfile?

  @@map("users")
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

// ─────────────────────────────────────────────
// 컬렉터 프로필 (User 1:1)
// ─────────────────────────────────────────────
model CollectorProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  nickname          String?
  bio               String?
  avatarUrl         String?
  region            String?
  snsUrl            String?
  bankAccountInfo   String?
  bankAccountHolder String?
  bankPublic        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("collector_profiles")
}

// ─────────────────────────────────────────────
// 품종 (Species) — displayName 중심 마스터
//
// 다육 시장 특성 반영:
//   - 학명 미상 (scientificName null + taxonRank SP)
//   - 유통명만 존재 (displayName에 "Pink Ruby" 등)
//   - sp / ssp / 교배종 / 필드넘버 / 판매자명
// ─────────────────────────────────────────────
model Species {
  id                       String     @id @default(cuid())
  displayName              String
  scientificName           String?
  englishName              String?
  koreanName               String?
  fieldNumber              String?
  sellerName               String?
  taxonRank                TaxonRank  @default(SPECIES)
  isHybrid                 Boolean    @default(false)
  parentSpecies1Id         String?
  parentSpecies2Id         String?
  categoryId               String?
  family                   String?
  genus                    String?
  description              String?
  careGuide                String?
  defaultWateringCycleDays Int?
  thumbnailUrl             String?
  isActive                 Boolean    @default(true)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  parentSpecies1  Species?  @relation("HybridParent1", fields: [parentSpecies1Id], references: [id])
  parentSpecies2  Species?  @relation("HybridParent2", fields: [parentSpecies2Id], references: [id])
  childrenAsParent1 Species[] @relation("HybridParent1")
  childrenAsParent2 Species[] @relation("HybridParent2")
  category        PlantCategory? @relation(fields: [categoryId], references: [id])

  plants Plant[]

  @@index([displayName])
  @@index([scientificName])
  @@index([fieldNumber])
  @@index([genus])
  @@index([categoryId])
  @@map("species")
}

enum TaxonRank {
  SPECIES
  SP
  SSP
  VARIETY
  CULTIVAR
  HYBRID
}

// ─────────────────────────────────────────────
// 위치 (계층 구조 + 지도 좌표)
// imagePath: 위치 평면도/배치도 이미지
// posX, posY: 이미지 위 상대 좌표 (0.0 ~ 1.0)
// ─────────────────────────────────────────────
model PlantLocation {
  id          String   @id @default(cuid())
  code        String
  name        String
  description String?
  ownerId     String
  typeId      String?
  parentId    String?
  imagePath   String?
  posX        Float?
  posY        Float?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User            @relation("LocationOwner", fields: [ownerId], references: [id])
  type     CommonCode?     @relation("LocationType", fields: [typeId], references: [id])
  parent   PlantLocation?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children PlantLocation[] @relation("LocationHierarchy")

  plants        Plant[]
  historiesFrom PlantHistory[] @relation("HistoryFromLocation")
  historiesTo   PlantHistory[] @relation("HistoryToLocation")

  @@unique([ownerId, code])
  @@index([ownerId])
  @@index([parentId])
  @@index([typeId])
  @@map("plant_locations")
}

enum LifeCycleStage {
  SEED
  SOWING
  SEEDLING
  ADULT
  FOR_SALE
  SOLD
  PRESERVED
}

// ─────────────────────────────────────────────
// 개체 (Plant) — QR로 식별되는 개별 다육
// qrCode: QrSequence + Species.category.code 로 발급
// parentPlantId: 삽목·분지·접목 등 번식 원본 개체
// deletedAt: Soft Delete — null이면 정상, 값이 있으면 삭제 처리된 개체 (RULES.md 기준)
// ─────────────────────────────────────────────
model Plant {
  id             String     @id @default(cuid())
  qrCode         String     @unique
  nickname       String?
  speciesId      String
  locationId     String?
  ownerId        String
  isPublic       Boolean    @default(false)
  lifeCycleStage LifeCycleStage?
  parentPlantId  String?
  parentPlant1Id String?
  parentPlant2Id String?
  statusId       String
  originTypeId   String
  purchasePrice     Decimal?   @db.Decimal(12, 2)
  sellingPrice      Decimal?   @db.Decimal(12, 2)
  flowerColor       String?
  purchaseHeadCount Int?
  purchaseUnitPrice Decimal?   @db.Decimal(12, 2)
  currentHeadCount  Int?
  unitSellingPrice  Decimal?   @db.Decimal(12, 2)
  totalSellingPrice Decimal?   @db.Decimal(12, 2)
  purchaseVendor    String?
  purchaseFarm      String?
  purchaseDate      DateTime?
  seedDate       DateTime?
  potSize        String?
  memo           String?
  soldAt         DateTime?
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  species     Species        @relation(fields: [speciesId], references: [id])
  location    PlantLocation? @relation(fields: [locationId], references: [id])
  owner       User?          @relation("PlantOwner", fields: [ownerId], references: [id])
  parentPlant Plant?         @relation("PlantLineage", fields: [parentPlantId], references: [id])
  parentPlant1 Plant?        @relation("PlantParent1", fields: [parentPlant1Id], references: [id])
  parentPlant2 Plant?        @relation("PlantParent2", fields: [parentPlant2Id], references: [id])
  childPlants Plant[]        @relation("PlantLineage")
  childrenAsParent1 Plant[]  @relation("PlantParent1")
  childrenAsParent2 Plant[]  @relation("PlantParent2")
  status      CommonCode     @relation("PlantStatus", fields: [statusId], references: [id])
  originType  CommonCode     @relation("OriginType", fields: [originTypeId], references: [id])
  images      PlantImage[]
  histories   PlantHistory[]
  cartItems   Cart[]

  @@index([speciesId])
  @@index([locationId])
  @@index([ownerId])
  @@index([isPublic])
  @@index([parentPlantId])
  @@index([parentPlant1Id])
  @@index([parentPlant2Id])
  @@index([lifeCycleStage])
  @@index([statusId])
  @@index([originTypeId])
  @@index([deletedAt])
  @@map("plants")
}

// ─────────────────────────────────────────────
// originType은 CommonCode(groupCode: ORIGIN_TYPE)로 관리한다.
// 기존 enum(PURCHASE, SEEDLING, CUTTING, OFFSET, GRAFT)에서 전환.
// 향후 교환(EXCHANGE), 나눔(DONATION), 수입(IMPORT), 채종(SEED_COLLECTED)
// 등을 코드 추가만으로 확장 가능하다.
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// 개체 이미지
// ─────────────────────────────────────────────
model PlantImage {
  id        String    @id @default(cuid())
  plantId   String
  ownerId   String
  url       String
  imageType ImageType @default(OTHER)
  caption   String?
  sortOrder Int       @default(0)
  isPrimary Boolean   @default(false)
  createdAt DateTime  @default(now())

  plant     Plant          @relation(fields: [plantId], references: [id], onDelete: Cascade)
  owner     User           @relation("ImageOwner", fields: [ownerId], references: [id])
  histories PlantHistory[] @relation("HistoryImage")

  @@index([plantId])
  @@index([ownerId])
  @@index([plantId, imageType])
  @@map("plant_images")
}

enum ImageType {
  PRIMARY
  FLOWER
  SALE
  OTHER
}

// ─────────────────────────────────────────────
// 개체 이력 — 분갈이, 판매, 위치변경, 개화, 메모 등
// historyType → CommonCode (groupCode: HISTORY_TYPE)
// imageId: 분갈이 사진, 꽃 사진, 판매 사진 등 이력과 이미지를 연결
// ─────────────────────────────────────────────
model PlantHistory {
  id             String   @id @default(cuid())
  plantId        String
  ownerId        String
  historyTypeId  String
  performedById  String?
  performedAt    DateTime @default(now())
  title          String?
  description    String?
  amount         Decimal? @db.Decimal(12, 2)
  fromLocationId String?
  toLocationId   String?
  imageId        String?
  metadata       Json?
  createdAt      DateTime @default(now())

  plant        Plant          @relation(fields: [plantId], references: [id], onDelete: Cascade)
  owner        User           @relation("HistoryOwner", fields: [ownerId], references: [id])
  historyType  CommonCode     @relation("HistoryType", fields: [historyTypeId], references: [id])
  performedBy  User?          @relation("HistoryPerformer", fields: [performedById], references: [id])
  fromLocation PlantLocation? @relation("HistoryFromLocation", fields: [fromLocationId], references: [id])
  toLocation   PlantLocation? @relation("HistoryToLocation", fields: [toLocationId], references: [id])
  image        PlantImage?    @relation("HistoryImage", fields: [imageId], references: [id], onDelete: SetNull)

  @@index([plantId, performedAt])
  @@index([ownerId])
  @@index([historyTypeId])
  @@index([performedById])
  @@index([imageId])
  @@map("plant_histories")
}

// ─────────────────────────────────────────────
// 장바구니
// ─────────────────────────────────────────────
model Cart {
  id        String   @id @default(cuid())
  userId    String
  plantId   String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([userId, plantId])
  @@index([userId])
  @@map("carts")
}

// ─────────────────────────────────────────────
// 공개 구매 요청 (결제 전 — 관리자 확인용)
// ─────────────────────────────────────────────
model OrderRequest {
  id            String   @id @default(cuid())
  sessionId     String?
  userId        String?
  customerName  String?
  customerPhone String?
  customerEmail String?
  items         Json
  totalAmount   Decimal  @db.Decimal(12, 2)
  status        String   @default("PENDING")
  memo          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([sessionId])
  @@index([userId])
  @@map("order_requests")
}

// ─────────────────────────────────────────────
// 시스템 설정 (싱글톤 id='default')
// ─────────────────────────────────────────────
model SystemSettings {
  id                     String   @id @default("default")
  serviceName            String   @default("Ask Plant")
  defaultLanguage        String   @default("ko")
  defaultPlantStatusCode String   @default("FOR_SALE")
  notifyOrder            Boolean  @default(true)
  notifyLowStock         Boolean  @default(true)
  notifyWeeklyReport     Boolean  @default(false)
  qrCodeDigits           Int      @default(6)
  labelPaperSize         String   @default("40mm x 30mm")
  bankAccountInfo        String?
  bankAccountHolder      String?
  updatedAt              DateTime @updatedAt

  @@map("system_settings")
}
